# ===========================================================================
# .env.example — Ortam Değişkenleri Şablonu
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.
# .env dosyasını asla git'e commit ETMEYİN!
# ===========================================================================

# Django
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_SECRET_KEY=buraya-guclu-bir-secret-key-girin-en-az-50-karakter

# PostgreSQL
DB_NAME=malpractice_dss
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432

# CORS (üretimde virgülle ayırın)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Üretim sunucusu
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
